# Copy this file to .env and fill with real values. Do NOT commit secrets to git.

# MongoDB connection
MONGO_URI=mongodb://localhost:27017/storeitnow

# JWT secret
JWT_SECRET=your_jwt_secret_here

# Razorpay keys (fill with your account keys)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_key_secret

# Other optional settings
PORT=3000
